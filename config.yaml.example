# FX Portfolio 配置文件示例
# 复制此文件为 config.yaml 并根据实际情况修改
# 或使用环境变量覆盖（推荐用于生产环境）

# 数据库配置
# 支持的数据库类型: mysql, postgres, sqlite
database:
  type: "mysql"  # 数据库类型: mysql, postgres, sqlite

  # MySQL/PostgreSQL 配置
  host: "172.23.112.1"
  port: 3306
  user: "admin"
  password: "ctsi@Passw0rd"
  name: "insight_onchain"
  charset: "utf8mb4"  # 仅MySQL有效
  ssl_mode: "disable" # 仅PostgreSQL有效 (disable, require, verify-ca, verify-full)

  # SQLite 配置 (使用SQLite时，host/port/user/password/name无效)
  # path: "./fx.db"   # SQLite数据库文件路径

  # 连接池配置
  pool:
    max_idle_conns: 10        # 最大空闲连接数
    max_open_conns: 100       # 最大打开连接数
    conn_max_lifetime: "1h"   # 连接最大生命周期 (如: 1h, 30m)
    conn_max_idle_time: "30m" # 连接最大空闲时间 (如: 30m, 10m)

  # 日志级别: silent, error, warn, info
  # 空字符串表示根据环境自动选择 (debug模式=info, release模式=silent)
  log_level: ""

# API Keys
api:
  coincap_key: "b617d9cf029dbb40f02b058a0e74919176b768cf36fd1ea6fae55a13a1610f41"  # CoinCap API Key，用于获取加密货币价格
  tushare_key: "971814b300986732ce339c9572864f52911cb1642dfceb2e8990f535"  # Tushare API Token，用于获取美股价格

# 服务器配置
server:
  port: "8080"
  mode: "release"  # debug 或 release

# JWT 配置
jwt:
  secret: "132fd39d-d6ea-468a-9ec8-31f1ccad09b2"
  expires_in: 24  # 小时

# 日志配置
log:
  level: "info"   # debug, info, warn, error
  format: "text"  # text 或 json

# ============================================
# 不同数据库配置示例
