{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "portfolio/*.go",
      "use": "@vercel/go"
    },
    {
      "src": "auth/*.go",
      "use": "@vercel/go"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "auth/index.go"
    },
    {
      "src": "/api/portfolio/(.*)",
      "dest": "portfolio/index.go"
    },
    {
      "src": "/api/prices/(.*)",
      "dest": "portfolio/index.go"
    }
  ]
}
